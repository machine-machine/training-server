# Coolify Deployment Environment Variables
# Copy this to .env and update REGISTRY_OWNER with your GitHub org/username

# GitHub Container Registry owner (your GitHub org or username, lowercase)
# Example: REGISTRY_OWNER=my-org (results in ghcr.io/my-org/training-api:latest)
REGISTRY_OWNER=your-github-org-or-username

# Database credentials (change for production!)
POSTGRES_USER=training
POSTGRES_PASSWORD=training
POSTGRES_DB=training

# Application environment
APP_ENV=production

# HotPath gRPC target (update to your HotPath service address)
HOTPATH_GRPC_TARGET=hotpath:50051

# Artifact storage location (persistent volume)
ARTIFACT_ROOT=/workspace/models

# GPU Configuration (adjust based on your hardware)
CUDA_VISIBLE_DEVICES=0,1
NCCL_SOCKET_IFNAME=eth0
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512
